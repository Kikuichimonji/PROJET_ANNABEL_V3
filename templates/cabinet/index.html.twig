{% extends 'base.html.twig' %}
{% block title %}Liste Cabinet{% endblock %}
{% block nav %}{{ include('_nav.html.twig') }}{% endblock %}
{% block body %}
<div id="adminListWrap">
    <a class="btn-primary" href="{{path('admin_add_cabinet')}}">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Ajouter un nouveau cabinet
    </a>
    <table>
        <thead>
            <tr>
                <th>Nom du cabinet</th>
                <th>Modifier</th>
                <th>Supprimer</th>
            </tr>
        </thead>
        <tbody>
            {% for cabinet in cabinets %}

            <tr>
                <td>{{cabinet.libelle}}</td>
                <td><a class="admin" href="{{path('admin_edit_cabinet',{'id':cabinet.id})}}">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                </a></td>
                <td><a class="admin" href="{{path('admin_delete_cabinet',{'id':cabinet.id})}}">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                </a></td>
            </tr>

            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
