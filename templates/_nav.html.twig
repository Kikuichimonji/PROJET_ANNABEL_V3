{#
    Barre de navigation partagee. Parametres optionnels a passer via include() :
    - cabinets    : liste des cabinets a afficher dans le selecteur (onglets a gauche)
    - centerTitle : texte affiche au centre (nom du patient sur la fiche, sinon le nom de l'appli)
#}
{% set currentCabinet = app.session.get('cabinet') %}
{% set currentCabinetId = currentCabinet ? currentCabinet.getId() : 0 %}

<nav id="navbar">
    {% if cabinets is defined and cabinets %}
        <div id="navbarLeft">
            <span id="cabinetFull">
                <ul class="nav-cabinet-list">
                {% for cabinet in cabinets %}
                    {% if currentCabinet %}
                        <li class="{{ cabinet.id == currentCabinetId ? 'uk-active' : '' }}">
                            <a href="{{ path('home_detail', {'id': cabinet.id}) }}">{{ cabinet.libelle|upper|e }}</a>
                        </li>
                    {% endif %}
                {% endfor %}
                </ul>
            </span>
            <span id="cabinetSmall">
                <ul class="nav-cabinet-list">
                    <li class="nav-cabinet-dropdown-wrap">
                        <a class="nav-cabinet-toggle" href="#" tabindex="0">
                            <span class="nav-caret"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></span>
                            <span>Cabinets</span>
                        </a>
                        <div class="nav-cabinet-dropdown">
                            <ul class="nav-cabinet-list">
                            {% for cabinet in cabinets %}
                                {% if currentCabinet %}
                                    <li class="{{ cabinet.id == currentCabinetId ? 'uk-active' : '' }}">
                                        <a href="{{ path('home_detail', {'id': cabinet.id}) }}">{{ cabinet.libelle|e }}</a>
                                    </li>
                                {% endif %}
                            {% endfor %}
                            </ul>
                        </div>
                    </li>
                    <li class="uk-active">
                        <a href="#">{{ currentCabinet ? currentCabinet.getLibelle()|e : '' }}</a>
                    </li>
                </ul>
            </span>
        </div>
    {% endif %}
    <div id="navbarCenter"><a href="{{ path('home_detail', {'id': currentCabinetId}) }}">{{ centerTitle is defined and centerTitle ? centerTitle : 'OsteoClic' }}</a></div>
    {% if app.user %}
        <div id="navbarRight">
            <span id="connect">Connecté en tant que</span>
            <span class="userBadge">{{ app.user.username|e }}</span>
            <a id="logoutLink" href="{{ path('app_logout') }}" title="Se déconnecter">✕</a>
        </div>
    {% endif %}
</nav>
